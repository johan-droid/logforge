# API server
NODE_ENV=development
PORT=3001
DATABASE_URL=logforge.db
JWT_SECRET=replace-me
ENCRYPTION_KEY=12345678901234567890123456789012
WEB_BASE_URL=http://localhost:3000

# Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Provider OAuth defaults
RENDER_CLIENT_ID=
RENDER_CLIENT_SECRET=
RENDER_AUTH_URL=https://dashboard.render.com/oauth/authorize
RENDER_TOKEN_URL=https://api.render.com/oauth/token
RENDER_SCOPES=read

VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_AUTH_URL=https://vercel.com/oauth/authorize
VERCEL_TOKEN_URL=https://api.vercel.com/v2/oauth/access_token
VERCEL_SCOPES=read

HEROKU_CLIENT_ID=
HEROKU_CLIENT_SECRET=
HEROKU_AUTH_URL=https://id.heroku.com/oauth/authorize
HEROKU_TOKEN_URL=https://id.heroku.com/oauth/token
HEROKU_SCOPES=read

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_CLIENT_ID=
CLOUDFLARE_CLIENT_SECRET=
CLOUDFLARE_AUTH_URL=https://dash.cloudflare.com/oauth2/auth
CLOUDFLARE_TOKEN_URL=https://api.cloudflare.com/client/v4/user/tokens/verify
CLOUDFLARE_SCOPES=Account:Read Workers Scripts:Read Pages:Read

RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=
RAILWAY_AUTH_URL=https://backboard.railway.app/oauth/authorize
RAILWAY_TOKEN_URL=https://backboard.railway.app/oauth/token
RAILWAY_SCOPES=read
