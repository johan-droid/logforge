{
  "name": "logforge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "render-build": "pnpm install && pnpm build",
    "render-start": "pnpm start",
    "dev": "turbo run dev",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "lint": "turbo run lint",
    "test": "pnpm check:secrets && turbo run test",
    "ci": "pnpm lint && pnpm build && pnpm test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "typecheck": "pnpm check-types",
    "check:secrets": "tsx scripts/check-no-secret-logging.ts"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "next>postcss": "^8.5.15",
    "next@16.2.6>postcss": "^8.5.15"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x"
  }
}
